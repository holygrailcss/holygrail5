{
  "name": "holygrail5",
  "version": "1.0.27",
  "description": "Framework CSS generator con Node.js - Genera CSS optimizado con variables CSS desde un archivo JSON de configuración",
  "main": "generate-css.js",
  "style": "dist/output.css",
  "exports": {
    ".": {
      "default": "./generate-css.js"
    },
    "./dist/output": "./dist/output.css",
    "./dist/dutti": "./dist/themes/dutti.css"
  },
  "bin": {
    "holygrail5": "./generate-css.js"
  },
  "scripts": {
    "build": "node generate-css.js",
    "prepack": "npm run build",
    "watch": "node src/watch-config.js",
    "serve": "node src/dev-server.js",
    "dev": "node src/dev-server.js",
    "start": "npm run build && npm run serve",
    "test": "node tests/run-all.js",
    "publish:pkg": "npm test && npm publish",
    "vars:report": "node src/docs-generator/variables-cli.js report",
    "vars:remove-unused": "node src/docs-generator/variables-cli.js remove-all-unused"
  },
  "keywords": [
    "css",
    "framework",
    "generator",
    "css-variables",
    "responsive",
    "typography",
    "css-framework",
    "design-tokens"
  ],
  "author": "HolyGrail CSS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/holygrailcss/holygrail5.git"
  },
  "files": [
    "generate-css.js",
    "config.json",
    "README.md",
    "src/**/*.js",
    "src/docs-generator/guide-styles.css",
    "src/assets/fonts/**",
    "src/assets/js/**",
    "src/assets/intro.jpg",
    "src/assets/introm.jpg",
    "src/assets/margen.webp",
    "themes/**/*",
    "dist/output.css",
    "dist/guide-styles.css",
    "dist/index.html",
    "dist/componentes.html",
    "dist/skills.html",
    "dist/developer-guide.md",
    "dist/assets/**",
    "dist/themes/**"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
